# Copy this file to ".env" and adjust as needed.
# All values have sensible defaults in app/core/config.py — nothing here is
# required while the API runs on mock data.

# --- Application ---
PROJECT_NAME="SBS Data Factory — Drive-to-Store DSP API"
API_PREFIX=/api

# --- Database (PostgreSQL) ---
# Only needed once you wire the real database (see README "Brancher PostgreSQL").
DATABASE_URL=postgresql+psycopg2://sbs:sbs@localhost:5432/sbs_dsp

# --- CORS (frontend dev servers, comma-separated) ---
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173
